// API Configuration
// All keys live in Config.local.xcconfig (gitignored) for local builds.
// Xcode Cloud injects via ci_post_clone.sh from environment variables.
// The "Inject API Keys" build script patches plists in the built bundle.

#include? "Config.local.xcconfig"

// These build settings are read by the "Inject API Keys" run script phase
ANTHROPIC_API_KEY = $(ANTHROPIC_API_KEY)
LANGSMITH_API_KEY = $(LANGSMITH_API_KEY)
FIREBASE_API_KEY = $(FIREBASE_API_KEY)
